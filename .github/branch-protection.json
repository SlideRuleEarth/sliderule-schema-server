{
  "//": "Branch protection draft for `main` — apply via:",
  "//apply": "gh api -X PUT repos/SlideRuleEarth/sliderule-schema-server/branches/main/protection --input .github/branch-protection.json",
  "//unapply": "gh api -X DELETE repos/SlideRuleEarth/sliderule-schema-server/branches/main/protection",

  "required_status_checks": {
    "strict": true,
    "contexts": ["verify"]
  },

  "enforce_admins": true,

  "required_pull_request_reviews": {
    "required_approving_review_count": 1,
    "dismiss_stale_reviews": true,
    "require_code_owner_reviews": false,
    "require_last_push_approval": false
  },

  "restrictions": null,

  "required_linear_history": false,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "required_conversation_resolution": true,
  "block_creations": false,
  "lock_branch": false,
  "allow_fork_syncing": false
}
